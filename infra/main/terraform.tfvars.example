github_repository          = "YOUR_GITHUB_OWNER/PokeTracker"
alert_recipient_email      = "you@example.com"
checkout_webhook_url       = "https://checkout.example.com/purchase"
target_place_order_enabled = false
target_session_refresh_enabled             = true
target_session_refresh_schedule_expression = "cron(45 6,7 * * ? *)"
