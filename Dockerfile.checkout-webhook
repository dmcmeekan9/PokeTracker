FROM mcr.microsoft.com/playwright/python:v1.48.0-jammy

WORKDIR /function

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/function/src

COPY pyproject.toml README.md ./
COPY src ./src

RUN python -m pip install --no-cache-dir \
    awslambdaric \
    "boto3>=1.34.0" \
    "PyYAML>=6.0.1" \
    "requests>=2.32.0" \
    "playwright==1.48.0"

ENTRYPOINT ["python", "-m", "awslambdaric"]
CMD ["poketracker.checkout_webhook.handler.lambda_handler"]
